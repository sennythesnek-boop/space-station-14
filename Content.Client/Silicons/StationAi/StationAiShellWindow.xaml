<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'station-ai-shell-window-title'}"
               MinSize="450 450" SetSize="450 450">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True">
        <LineEdit Name="SearchBar" PlaceHolder="{Loc 'station-ai-shell-window-search'}" HorizontalExpand="True" Margin="0 4" />
        <ScrollContainer Name="ShellScroll" VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
            <BoxContainer Name="ButtonContainer" Orientation="Vertical" VerticalExpand="True" SeparationOverride="5">
                <!-- Shell buttons get added here by code -->
            </BoxContainer>
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>
