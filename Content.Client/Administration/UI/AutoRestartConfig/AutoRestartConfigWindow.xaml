<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc auto-restart-config-title}"
                      Resizable="True"
                      MinSize="340 260"
                      SetSize="420 300">
    <PanelContainer StyleClasses="BackgroundDark">
        <BoxContainer Orientation="Vertical" Margin="8" HorizontalExpand="True">

            <Label Text="{Loc auto-restart-config-settings}" StyleClasses="LabelHeading" />
            <CheckBox Name="EnabledCheck" Text="{Loc auto-restart-config-enabled}" />

            <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
                <Label Text="{Loc auto-restart-config-time}" MinWidth="180" />
                <LineEdit Name="TimeEdit" MinWidth="80" PlaceHolder="03:00" />
                <Button Name="ApplyTimeButton" Text="{Loc auto-restart-config-apply}" Margin="4 0 0 0" />
            </BoxContainer>

            <Label Text="{Loc auto-restart-config-clock}" StyleClasses="LabelHeading" Margin="0 12 0 2" />
            <Label Name="ServerTimeLabel" />
            <Label Name="NextRestartLabel" />
            <Label Name="StatusLabel" Margin="0 6 0 0" />

            <Label Text="{Loc auto-restart-config-hint}" Margin="0 12 0 0" StyleClasses="LabelSubText" />

        </BoxContainer>
    </PanelContainer>
</controls:FancyWindow>
