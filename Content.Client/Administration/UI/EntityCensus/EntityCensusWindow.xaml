<ui:FancyWindow xmlns="https://spacestation14.io"
                xmlns:ui="clr-namespace:Content.Client.UserInterface.Controls"
                Title="{Loc entity-census-title}"
                MinSize="520 360"
                SetSize="620 560">
    <PanelContainer StyleClasses="BackgroundDark">
        <BoxContainer Orientation="Vertical" Margin="4">
            <BoxContainer Orientation="Horizontal" Margin="0 0 0 4">
                <Label Name="TotalLabel" StyleClasses="LabelHeading" HorizontalExpand="True" />
                <LineEdit Name="FilterEdit" PlaceHolder="{Loc entity-census-filter}" MinWidth="160" />
            </BoxContainer>
            <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
                <GridContainer Name="CensusGrid" Columns="4" HorizontalExpand="True" />
            </ScrollContainer>
        </BoxContainer>
    </PanelContainer>
</ui:FancyWindow>
