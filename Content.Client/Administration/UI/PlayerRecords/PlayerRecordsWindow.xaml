<ui:FancyWindow xmlns="https://spacestation14.io"
                xmlns:ui="clr-namespace:Content.Client.UserInterface.Controls"
                Title="{Loc player-records-title}"
                Resizable="True"
                MinSize="480 300"
                SetSize="1000 620">
    <PanelContainer StyleClasses="BackgroundDark">
        <BoxContainer Orientation="Vertical" Margin="4">
            <BoxContainer Orientation="Horizontal" Margin="0 0 0 4">
                <LineEdit Name="SearchBar" HorizontalExpand="True"
                          PlaceHolder="{Loc player-records-search-placeholder}" />
                <Button Name="SearchButton" Text="{Loc player-records-search-button}" Margin="4 0 0 0" />
            </BoxContainer>
            <ScrollContainer Name="Scroll" VerticalExpand="True" HorizontalExpand="True"
                             HScrollEnabled="True" VScrollEnabled="True">
                <BoxContainer Name="ListContainer" Orientation="Vertical" />
            </ScrollContainer>
            <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
                <Button Name="PrevButton" Text="{Loc player-records-prev}" />
                <Label Name="PageLabel" Margin="8 0" />
                <Button Name="NextButton" Text="{Loc player-records-next}" />
                <Control HorizontalExpand="True" />
                <Label Name="CountLabel" />
            </BoxContainer>
        </BoxContainer>
    </PanelContainer>
</ui:FancyWindow>
