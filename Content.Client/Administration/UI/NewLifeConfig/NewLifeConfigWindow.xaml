<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc new-life-config-title}"
                      Resizable="True"
                      MinSize="360 560"
                      SetSize="580 720">
    <PanelContainer StyleClasses="BackgroundDark">
        <ScrollContainer HScrollEnabled="False" VerticalExpand="True" HorizontalExpand="True">
            <BoxContainer Orientation="Vertical" Margin="6" HorizontalExpand="True">

                <Label Text="{Loc new-life-config-settings}" StyleClasses="LabelHeading" />
                <CheckBox Name="EnabledCheck" Text="{Loc new-life-config-enabled}" />
                <CheckBox Name="KeepAntagCheck" Text="{Loc new-life-config-keep-antag}" />

                <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
                    <Label Text="{Loc new-life-config-cooldown}" MinWidth="180" />
                    <LineEdit Name="CooldownEdit" MinWidth="100" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
                    <Label Text="{Loc new-life-config-max}" MinWidth="180" />
                    <LineEdit Name="MaxEdit" MinWidth="100" />
                </BoxContainer>

                <Label Name="StatusLabel" Margin="0 8 0 0" />

                <Label Text="{Loc new-life-config-blocklist}" StyleClasses="LabelHeading" Margin="0 12 0 2" />
                <Label Text="{Loc new-life-config-blocklist-hint}" Margin="0 0 0 4" />
                <BoxContainer Orientation="Horizontal">
                    <OptionButton Name="ProfileOption" MinWidth="150" />
                    <Button Name="DeleteButton" Text="{Loc new-life-config-delete}" Margin="4 0 0 0" />
                    <LineEdit Name="NameEdit" PlaceHolder="{Loc new-life-config-new-name}" MinWidth="110" HorizontalExpand="True" Margin="8 0 0 0" />
                    <Button Name="CreateButton" Text="{Loc new-life-config-create}" Margin="4 0 0 0" />
                </BoxContainer>
                <BoxContainer Name="EventList" Orientation="Vertical" Margin="0 2 0 0" />

            </BoxContainer>
        </ScrollContainer>
    </PanelContainer>
</controls:FancyWindow>
