<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc vote-config-title}"
                      MinSize="540 560"
                      SetSize="580 720">
    <PanelContainer StyleClasses="BackgroundDark">
        <ScrollContainer HScrollEnabled="False" VerticalExpand="True" HorizontalExpand="True">
            <BoxContainer Orientation="Vertical" Margin="6">

                <Label Text="{Loc vote-config-votes}" StyleClasses="LabelHeading" />
                <CheckBox Name="VoteEnabledCheck" Text="{Loc vote-config-enabled}" />
                <CheckBox Name="RestartCheck" Text="{Loc vote-config-restart}" />
                <CheckBox Name="PresetCheck" Text="{Loc vote-config-preset}" />
                <CheckBox Name="MapCheck" Text="{Loc vote-config-map}" />
                <CheckBox Name="VotekickCheck" Text="{Loc vote-config-votekick}" />

                <Label Text="{Loc vote-config-maps}" StyleClasses="LabelHeading" Margin="0 12 0 2" />
                <BoxContainer Orientation="Horizontal">
                    <OptionButton Name="MapProfileOption" MinWidth="150" />
                    <Button Name="MapDeleteButton" Text="{Loc vote-config-delete}" Margin="4 0 0 0" />
                    <LineEdit Name="MapNameEdit" PlaceHolder="{Loc vote-config-new-name}" MinWidth="110" HorizontalExpand="True" Margin="8 0 0 0" />
                    <Button Name="MapCreateButton" Text="{Loc vote-config-create}" Margin="4 0 0 0" />
                </BoxContainer>
                <BoxContainer Name="MapList" Orientation="Vertical" Margin="0 2 0 0" />

                <Label Text="{Loc vote-config-gamemodes}" StyleClasses="LabelHeading" Margin="0 12 0 2" />
                <BoxContainer Orientation="Horizontal">
                    <OptionButton Name="PresetProfileOption" MinWidth="150" />
                    <Button Name="PresetDeleteButton" Text="{Loc vote-config-delete}" Margin="4 0 0 0" />
                    <LineEdit Name="PresetNameEdit" PlaceHolder="{Loc vote-config-new-name}" MinWidth="110" HorizontalExpand="True" Margin="8 0 0 0" />
                    <Button Name="PresetCreateButton" Text="{Loc vote-config-create}" Margin="4 0 0 0" />
                </BoxContainer>
                <BoxContainer Name="PresetList" Orientation="Vertical" Margin="0 2 0 0" />

            </BoxContainer>
        </ScrollContainer>
    </PanelContainer>
</controls:FancyWindow>
