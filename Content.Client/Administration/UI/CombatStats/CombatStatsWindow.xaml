<ui:FancyWindow xmlns="https://spacestation14.io"
                xmlns:ui="clr-namespace:Content.Client.UserInterface.Controls"
                Title="{Loc combat-stats-title}"
                MinSize="560 400"
                SetSize="660 560">
    <PanelContainer StyleClasses="BackgroundDark">
        <BoxContainer Orientation="Vertical" Margin="4">
            <BoxContainer Orientation="Horizontal" Margin="0 0 0 4">
                <Label Text="{Loc combat-stats-round-label}" VerticalAlignment="Center" Margin="0 0 4 0" />
                <Button Name="PrevRoundButton" Text="{Loc combat-stats-prev-round}" StyleClasses="ButtonSquare" />
                <OptionButton Name="RoundOption" />
                <Button Name="NextRoundButton" Text="{Loc combat-stats-next-round}" StyleClasses="ButtonSquare" />
                <Label Name="CountLabel" HorizontalExpand="True" StyleClasses="LabelHeading" Margin="8 0 0 0" />
                <Button Name="RefreshButton" Text="{Loc combat-stats-refresh}" />
            </BoxContainer>
            <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
                <GridContainer Name="StatsGrid" Columns="6" HorizontalExpand="True" />
            </ScrollContainer>
        </BoxContainer>
    </PanelContainer>
</ui:FancyWindow>
