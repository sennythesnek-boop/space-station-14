<ui:FancyWindow xmlns="https://spacestation14.io"
                xmlns:ui="clr-namespace:Content.Client.UserInterface.Controls"
                Title="{Loc role-times-title}"
                MinSize="500 400"
                SetSize="560 540">
    <PanelContainer StyleClasses="BackgroundDark">
        <BoxContainer Orientation="Vertical" Margin="4">
            <BoxContainer Orientation="Horizontal" Margin="0 0 0 4">
                <Label Name="PlayerLabel" HorizontalExpand="True" StyleClasses="LabelHeading" />
                <Label Name="StatusLabel" />
            </BoxContainer>
            <LineEdit Name="SearchBar" PlaceHolder="{Loc role-times-search-placeholder}" Margin="0 0 0 4" />
            <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                <BoxContainer Name="RolesContainer" Orientation="Vertical" Access="Public" VerticalExpand="True" />
            </ScrollContainer>
        </BoxContainer>
    </PanelContainer>
</ui:FancyWindow>
