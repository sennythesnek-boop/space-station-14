# roletimes command
cmd-roletimes-desc = Opens the role time overview for a player (online or offline) to view and adjust their per-role play time.
cmd-roletimes-help = Usage: roletimes <username/userid>
cmd-roletimes-server = This command cannot be run from the server console.
cmd-roletimes-invalid-arguments = Expected exactly one argument.
cmd-roletimes-invalid-player = Unable to find a player with that name or id.
cmd-roletimes-completion = Player

# Role time overview window
role-times-title = Role Times
role-times-search-placeholder = Search roles...
role-times-status-online = Online
role-times-status-offline = Offline
role-times-set-button = Set
role-times-edit-tooltip = Enter time as HH:MM, or a plain number of minutes.

# Requirement summaries shown under each role
role-times-requires = Requires: {$reqs}
role-times-req-overall = {$time} overall
role-times-req-overall-inverted = under {$time} overall
role-times-req-role = {$time} as {$role}
role-times-req-role-inverted = under {$time} as {$role}
role-times-req-department = {$time} in {$department}
role-times-req-department-inverted = under {$time} in {$department}
