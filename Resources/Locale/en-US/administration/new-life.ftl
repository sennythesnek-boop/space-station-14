# newlifeconfig command
cmd-newlifeconfig-desc = Opens the New Life configuration window (respawn toggle, cooldown, per-round cap, event blocklist).
cmd-newlifeconfig-help = Usage: newlifeconfig
cmd-newlifeconfig-server = This command cannot be run from the server console.

# New Life config window
new-life-config-title = New Life Config
new-life-config-settings = Settings
new-life-config-enabled = New Life enabled
new-life-config-keep-antag = Antagonists keep their antag role after respawn
new-life-config-cooldown = Cooldown (seconds)
new-life-config-max = Max new lives per round (0 = unlimited)
new-life-config-none = (none)
new-life-config-new-name = New profile name...
new-life-config-create = Create
new-life-config-delete = Delete
new-life-config-blocklist = Event blocklist
new-life-config-blocklist-hint = While any checked rule/event is active, players cannot take a new life. Select or create a profile, then tick the events to block.
new-life-config-status-ok = Status: new lives are currently allowed.
new-life-config-status-blocked = Status: blocked — { $reason }

# Ghost "New Life" button
new-life-button-ready = New Life
new-life-button-cooldown = New Life ({ $seconds }s)
new-life-button-blocked = New Life (unavailable)

# Blocked reasons
new-life-blocked-not-in-round = the round is not in progress
new-life-blocked-evac = the evacuation shuttle has been called
new-life-blocked-event = an active event ({ $event })

# Message shown to a player when they take a new life
new-life-reborn-message = You awaken as someone new. You remember nothing of your previous life — its people, its events, its grudges. Choose a new identity and begin again.
